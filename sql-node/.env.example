# --- Configurazione Database ---
# Tipo di database: mssql | mysql | postgres | oracle
DB_TYPE=mssql

DB_SERVER=localhost
DB_PORT=1433
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=mypassword

# Solo per SQL Server (opzionale)
DB_INSTANCE=

# Solo per Oracle (opzionale, alternativo a DB_NAME come service name)
DB_SID=
# Oppure una connect string completa per Oracle:
# DB_CONNECT_STRING=host:port/service

# --- Tunnel SSH (Opzionale) ---
# Se valorizzati, il server aprirà un tunnel SSH prima di connettersi al DB.
# SSH_HOST=ssh.example.com
# SSH_PORT=22
# SSH_USER=myuser
# SSH_PASSWORD=mypassword
# SSH_KEY_PATH=C:\Users\myuser\.ssh\id_rsa
