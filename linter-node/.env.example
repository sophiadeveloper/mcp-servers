# --- Configurazione Linter MCP ---

# Percorso completo del file JAR di CFLint
# Esempio: C:\tesisquare\cflint\CFLint-1.5.0-all.jar
CFLINT_JAR=

# Percorso completo dell'eseguibile Java (java.exe)
# Esempio: D:\programmi\ColdFusion2023\jre\bin\java.exe
JAVA_BIN=

# Percorso opzionale di un file .cflintrc globale (fallback se non trovato nel progetto)
# Esempio: C:\tesisquare\cflint\.cflintrc
CFLINT_CONFIG=
