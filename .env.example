# Configurazione Database per MCP
# Tipo: mssql | mysql | postgres | oracle
DB_TYPE=mssql
DB_SERVER=localhost
# Se usi una istanza con nome (MSSQL), usa ad esempio: DB_INSTANCE=SQLEXPRESS
DB_INSTANCE=
DB_PORT=1433

DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# --- Configurazione Mantis ---
MANTIS_URL=https://service.sophiainformatica.it/helpdesk/
MANTIS_TOKEN=your_token_here
MANTIS_PROJECT_ID=1;81

# --- Configurazione Linter ---
# Percorso completo del file JAR di CFLint
CFLINT_JAR=C:\path\to\CFLint-1.5.0-all.jar
# Percorso completo dell'eseguibile Java (java.exe)
JAVA_BIN=C:\path\to\java.exe
# Percorso opzionale di un file .cflintrc globale (fallback se non trovato nel progetto)
CFLINT_CONFIG=C:\path\to\.cflintrc
